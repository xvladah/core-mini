{
  "name": "xvladah/core-mini",
  "description": "Web mini Core",
  "version": "1.2.0",
  "type": "library",
  "license": "MIT",
  "autoload": {  
    "classmap": [
      "src/Database/DBO/",
      "src/Database/MySQL/",
      "src/Database/OCI8/",
      "src/",
      "src/Html/",
      "src/Http/",
      "src/Auth/",
      "src/Types/",
      "src/Auth/",
      "src/Templates/",
      "src/FormEngine/"
    ],
    "exclude-from-classmap": [
    ],
  
    "psr-4": {
      "core-mini\\": "src/"
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/xvladah/core-mini"
    }
  ],
  "require": {
    "ext-sqlite3": "*",
    "ext-oci8": "*",    
    "ext-mysqli": "*",
    "ext-mbstring": "*",
    "ext-iconv": "*",
    "ext-curl": "*",
    "ext-calendar": "*",
    "ext-gd": "*",
    "ext-zip": "*"
  }
}